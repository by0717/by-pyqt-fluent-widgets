app:
  window_count: 8
  scanner_timeout_ms: 50
  dpiScale: Auto
  language: zh_CN
device_templates:
  Oscilloscope:
    comm_method: VISA
    description: 示波器示例模板
    init_commands:
    - command: '*IDN?'
      wait_ms: 10
    name: Oscilloscope
    type: 示波器
  VISA通用设备:
    comm_method: VISA
    description: 通用VISA设备模板
    init_commands:
    - command: '*RST'
      wait_ms: 100
    - command: SYST:REM
      wait_ms: 50
    name: VISA通用设备
    type: 通用设备
devices:
  devices:
  - name: by_device_test
    type: 信号发生器
    comm_method: VISA
    description: 自定义设备模板 - by_device_test
    created_time: '2024-01-01'
    version: '1.0'
    manufacturer: Litepoint
    model: IQStream-5G
    visa_resource: 192.168.100.254
commands:
  protocol: telnet
  connection:
    host: 192.168.1.1
    port: 23
    username: admin
    password: admin
    timeout_ms: 3000
    retry_count: 3
    login_prompt: '>'
    separator: '|'
    end_char_return: Immediate
    ip_converter: Range
    ip_start: 192.168.1.2
    ip_end: 192.168.1.9
    ip_list: ''
    com_ports: None
    com_start: ''
    com_end: ''
    com_list: ''
    address_list:
    - 192.168.1.2
    - 192.168.1.3
    - 192.168.1.4
    - 192.168.1.5
    - 192.168.1.6
    - 192.168.1.7
    - 192.168.1.8
    - 192.168.1.9
  commands:
  - command_type: Character Command
    command: show version
    expect: Cisco
    end_char: '#'
    judge_type: Contains
    match_type: String Match
    variable: ''
  - command_type: Character Command
    command: show interfaces
    expect: up
    end_char: '#'
    judge_type: Contains
    match_type: String Match
    variable: ''
version_base: 1.1
ui:
  main_window:
    dpi_scale: Auto
    language: Auto
    mica_enabled: false
  theme:
    mode: Auto
    color: '#0078d4'
  material:
    blur_radius: 15
  folders:
    music: []
    download: app/download
  update:
    check_at_startup: true
